{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/erp-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=erp;Username=erp;Password=erp_dev"
  },
  "Jwt": {
    "Issuer": "erp.uft-davis",
    "Audience": "erp.uft-davis",
    "SigningKey": "REPLACE_WITH_64_BYTE_RANDOM_BASE64_SECRET_DO_NOT_COMMIT",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 14
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 2525,
    "UseStartTls": false,
    "Username": "",
    "Password": "",
    "FromName": "ERP UFT Davis",
    "FromAddress": "no-reply@uft-davis.local"
  },
  "Minio": {
    "Endpoint": "localhost:9000",
    "AccessKey": "erp_minio",
    "SecretKey": "erp_minio_dev",
    "UseSsl": false,
    "Bucket": "erp-uploads"
  },
  "Hangfire": {
    "DashboardEnabled": true,
    "DashboardPath": "/hangfire"
  },
  "DeviceIngest": {
    "HmacSecret": "REPLACE_WITH_DEVICE_HMAC_SECRET",
    "ToleranceSeconds": 300
  },
  "Attendance": {
    "ShiftStart": "09:00",
    "ShiftEnd": "18:00",
    "ToleranceMinutes": 15,
    "TimeZoneId": "Asia/Jakarta"
  }
}
