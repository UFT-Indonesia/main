## ─────────────────────────────────────────────────────────────────────────────
## .NET 10 / ASP.NET Core
## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore
## ─────────────────────────────────────────────────────────────────────────────

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET / .NET Core / .NET 10
project.lock.json
project.fragment.lock.json
artifacts/
*.user
*.suo
*.userosscache
*.sln.docstates

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# NuGet v3's project.json files produced in large amounts on each build
*.nuget.props
*.nuget.targets
# NuGet cache
.nuget/
packages/
!**/packages/build/

# Rider IDE
.idea/
*.sln.iml

# Visual Studio / VS Code
.vs/
.vscode/
*.rsuser

# dotenv environment variables file
.env
.env.local
.env.*.local

# ASP.NET Core — publish output & secrets
# Ignore environment-specific overrides (e.g. appsettings.Production.json)
# but keep the base appsettings.json (must NOT contain real secrets — use
# dotnet user-secrets or environment variables for sensitive values).
**/publish/
**/Properties/launchSettings.json
*appsettings.*.json
!*appsettings.json

# .NET Hot Reload
*.hotreload

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# xUnit
xunit.runner.json

# BenchmarkDotNet
BenchmarkDotNet.Artifacts/

# ──────────────────────────────────────────────────
## Next.js
## Get latest from https://github.com/github/gitignore/blob/main/Next.gitignore
## ──────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js
.pnp.cjs

# Next.js build output
.next/
out/

# Production build
build/
dist/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Local env files (already covered above, listed explicitly for Next.js context)
.env*.local

# Vercel deployment
.vercel

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# Turbopack / Turborepo
.turbo/

# Yarn / npm / pnpm lock (keep lock files, ignore caches)
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnpm-store/

# ESLint / Prettier cache
.eslintcache
.stylelintcache
.prettiercache

# Storybook build output
storybook-static/

# Cypress test artefacts
cypress/videos/
cypress/screenshots/

# PWA / next-pwa generated files
**/public/sw.js
**/public/workbox-*.js
**/public/worker-*.js
**/public/fallback-*.js
**/public/sw.js.map
**/public/workbox-*.js.map
